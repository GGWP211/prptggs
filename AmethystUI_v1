function AmethystGUI:CreateWindow(settings)
	local Theme = self.Theme[settings.Theme or "Amethyst"]
	local Window = {}
	Window.Tabs = {}
	Window.Main = nil
	Window.ScreenGui = nil

	local ScreenGui = create("ScreenGui",{
		Name="AmethystGUI",
		IgnoreGuiInset=true,
		ResetOnSpawn=false
	})

	if gethui then
		ScreenGui.Parent = gethui()
	else
		ScreenGui.Parent = CoreGui
	end

	local Main = create("Frame",{
		Size=UDim2.new(0,580,0,460),
		Position=UDim2.new(0.5,0,0.5,0),
		AnchorPoint=Vector2.new(0.5,0.5),
		BackgroundColor3=Theme.Background,
		Parent=ScreenGui
	})

	create("UICorner",{CornerRadius=UDim.new(0,18),Parent=Main})
	create("UIStroke",{Color=Theme.Stroke,Thickness=1.5,Parent=Main})

	Main.BackgroundTransparency=1
	Main.Size=UDim2.new(0,480,0,360)
	tween(Main,{
		BackgroundTransparency=0,
		Size=UDim2.new(0,580,0,460)
	},0.45)

	local Topbar = create("Frame",{
		Size=UDim2.new(1,0,0,60),
		BackgroundColor3=Theme.Topbar,
		Parent=Main
	})
	create("UICorner",{CornerRadius=UDim.new(0,18),Parent=Topbar})

	local Title = create("TextLabel",{
		Size=UDim2.new(1,-20,1,0),
		Position=UDim2.new(0,20,0,0),
		BackgroundTransparency=1,
		Text=settings.Name or "AmethystGUI",
		TextColor3=Theme.Text,
		TextSize=22,
		Font=Enum.Font.GothamBold,
		TextXAlignment=Enum.TextXAlignment.Left,
		Parent=Topbar
	})

	-- Drag
	do
		local dragging=false
		local dragStart,startPos

		Topbar.InputBegan:Connect(function(input)
			if input.UserInputType==Enum.UserInputType.MouseButton1 then
				dragging=true
				dragStart=input.Position
				startPos=Main.Position
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if dragging and input.UserInputType==Enum.UserInputType.MouseMovement then
				local delta=input.Position-dragStart
				Main.Position=UDim2.new(
					startPos.X.Scale,
					startPos.X.Offset+delta.X,
					startPos.Y.Scale,
					startPos.Y.Offset+delta.Y
				)
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType==Enum.UserInputType.MouseButton1 then
				dragging=false
			end
		end)
	end

	-- Tabs holder
	local TabHolder = create("Frame",{
		Size=UDim2.new(0,160,1,-60),
		Position=UDim2.new(0,0,0,60),
		BackgroundTransparency=1,
		Parent=Main
	})

	create("UIListLayout",{
		Padding=UDim.new(0,8),
		Parent=TabHolder
	})

	local Content = create("Frame",{
		Size=UDim2.new(1,-160,1,-60),
		Position=UDim2.new(0,160,0,60),
		BackgroundTransparency=1,
		Parent=Main
	})

	--//====================================================--
	--//                CREATE TAB FUNCTION               --
	--//====================================================--

	function Window:CreateTab(name)
		local Tab = {}

		local Button = create("TextButton",{
			Size=UDim2.new(1,-14,0,42),
			Position=UDim2.new(0,7,0,0),
			Text=name,
			BackgroundColor3=Theme.Element,
			TextColor3=Theme.Text,
			TextSize=14,
			Font=Enum.Font.GothamSemibold,
			Parent=TabHolder
		})
		create("UICorner",{CornerRadius=UDim.new(0,12),Parent=Button})
		create("UIStroke",{Color=Theme.Stroke,Parent=Button})

		local Page = create("ScrollingFrame",{
			Size=UDim2.new(1,0,1,0),
			CanvasSize=UDim2.new(0,0,0,0),
			ScrollBarImageTransparency=0.6,
			BackgroundTransparency=1,
			Visible=false,
			Parent=Content
		})

		local Layout = create("UIListLayout",{
			Padding=UDim.new(0,10),
			Parent=Page
		})

		Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			Page.CanvasSize=UDim2.new(0,0,0,Layout.AbsoluteContentSize.Y+15)
		end)

		Button.MouseEnter:Connect(function()
			tween(Button,{BackgroundColor3=Theme.ElementHover},0.2)
		end)

		Button.MouseLeave:Connect(function()
			tween(Button,{BackgroundColor3=Theme.Element},0.2)
		end)

		Button.MouseButton1Click:Connect(function()
			for _,v in pairs(Content:GetChildren()) do
				if v:IsA("ScrollingFrame") then
					v.Visible=false
				end
			end
			Page.Visible=true
		end)

		local function createElement(height)
			local Frame=create("Frame",{
				Size=UDim2.new(1,-20,0,height),
				Position=UDim2.new(0,10,0,0),
				BackgroundColor3=Theme.Element,
				Parent=Page
			})
			create("UICorner",{CornerRadius=UDim.new(0,14),Parent=Frame})
			create("UIStroke",{Color=Theme.Stroke,Parent=Frame})

			Frame.BackgroundTransparency=1
			tween(Frame,{BackgroundTransparency=0},0.35)

			Frame.MouseEnter:Connect(function()
				tween(Frame,{BackgroundColor3=Theme.ElementHover},0.2)
			end)
			Frame.MouseLeave:Connect(function()
				tween(Frame,{BackgroundColor3=Theme.Element},0.2)
			end)

			return Frame
		end

		-- Elements будут добавлены в PART 2

		return Tab
	end

	Window.Main = Main
	Window.ScreenGui = ScreenGui

	table.insert(self.Windows,Window)
	return Window
end

