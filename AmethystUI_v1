local function safeCall(func,...)
	if not func then return end
	local ok,res = pcall(func,...)
	if not ok then
		warn("AmethystGUI:",res)
		return nil
	end
	return res
end

local function ensureFolder(path)
	if makefolder and not isfolder(path) then
		safeCall(makefolder,path)
	end
end

