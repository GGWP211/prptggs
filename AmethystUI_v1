local function getKeyData()
	if isfile and isfile(KEY_FILE) then
		local raw=safeCall(readfile,KEY_FILE)
		return safeCall(HttpService.JSONDecode,HttpService,raw)
	end
	return nil
end

local function saveKeyData(data)
	if writefile then
		safeCall(writefile,KEY_FILE,HttpService:JSONEncode(data))
	end
end

local function getUserAuth()
	local path=AUTH_FOLDER.."/"..LocalPlayer.UserId..".json"
	if isfile and isfile(path) then
		local raw=safeCall(readfile,path)
		return safeCall(HttpService.JSONDecode,HttpService,raw)
	end
	return nil
end

local function saveUserAuth(hash)
	if writefile then
		safeCall(writefile,
			AUTH_FOLDER.."/"..LocalPlayer.UserId..".json",
			HttpService:JSONEncode({authorizedKeyHash=hash})
		)
	end
end

local function invalidateAllSessions()
	if delfolder then
		safeCall(delfolder,AUTH_FOLDER)
		ensureFolder(AUTH_FOLDER)
	end
end

