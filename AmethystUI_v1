		Text="",
		TextColor3=Theme.Danger,
		Font=Enum.Font.Gotham,
		TextSize=12,
		Parent=Main
	})

	Input.FocusLost:Connect(function()
		local entered=Input.Text
		if #entered==0 then return end

		local keyData=getKeyData()
		if not keyData then
			Status.Text="Ключ не установлен."
			return
		end

		if simpleHash(entered)==keyData.keyHash then
			saveUserAuth(keyData.keyHash)
			Gui:Destroy()
			callback(true)
		else
			Status.Text="Неверный ключ."
		end
	end)
end

--//====================================================--
--//                       INIT                        --
--//====================================================--

function AmethystGUI:Init()

	local keyData=getKeyData()

	-- First run
	if not keyData then
		if LocalPlayer.UserId==10908220603 then
			openAdminPanel()
			repeat task.wait(1) until getKeyData()
		else
			LocalPlayer:Kick("Ключ не установлен. Обратитесь к администратору.")
			return nil
		end
	end

	-- Session check
	local auth=getUserAuth()
	if auth and auth.authorizedKeyHash==keyData.keyHash then
		return self
	end

	local success=false
	openKeyUI(function(ok)
		success=ok
	end)

	repeat task.wait() until success

	return self
end

