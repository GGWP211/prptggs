local function simpleHash(str)
	local hash=0
	for i=1,#str do
		hash=(hash*31+string.byte(str,i))%2147483647
	end
	return tostring(hash)
end

-- Admin key GG_WSW (хранится только хеш)
local ADMIN_KEY_HASH = simpleHash("GG_WSW")

