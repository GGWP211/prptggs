--//                 CONFIG SYSTEM                     --
--//====================================================--

function AmethystGUI:SaveConfiguration(name)
	if not writefile then return end
	if not name then return end

	local data = {}

	for flag,element in pairs(self.Flags) do
		if element.Type=="Color" then
			data[flag] = {
				R = element.Value.R*255,
				G = element.Value.G*255,
				B = element.Value.B*255,
				A = element.ValueA or 1
			}
		else
			data[flag] = element.Value
		end
	end

	safeCall(writefile,CONFIG_FOLDER.."/"..name..".json",HttpService:JSONEncode(data))
end

function AmethystGUI:LoadConfiguration(name)
	if not readfile then return end
	if not name then return end

	local path = CONFIG_FOLDER.."/"..name..".json"
	if not isfile or not isfile(path) then return end

	local raw = safeCall(readfile,path)
	local decoded = safeCall(HttpService.JSONDecode,HttpService,raw)
	if not decoded then return end

	for flag,value in pairs(decoded) do
		if self.Flags[flag] then
			self.Flags[flag]:Set(value)
		end
	end
end

